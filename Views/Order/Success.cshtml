@{
    ViewData["Title"] = "Order Successful!";
}

<style>
    /* সাকসেস কার্ডের ডিজাইন */
    .success-card {
        border-radius: 20px;
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
        border: none;
        padding: 3rem 2rem;
        background-color: #ffffff;
    }

    /* আইকনের পেছনের হালকা সবুজ ব্যাকগ্রাউন্ড */
    .success-icon-wrapper {
        width: 120px;
        height: 120px;
        background: rgba(40, 167, 69, 0.1); /* হালকা সবুজ */
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem auto;
    }

    /* বড় টিক চিহ্নের স্টাইল এবং অ্যানিমেশন */
    .success-icon {
        font-size: 4.5rem;
        color: #28a745; /* গাঢ় সবুজ */
        animation: popIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
    }

    /* পপ-আপ অ্যানিমেশন লজিক (এখানে @@ ব্যবহার করা হয়েছে) */
    @@keyframes popIn {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    /* অর্ডার আইডির বক্স */
    .order-id-box {
        background-color: #f8f9fa;
        border: 2px dashed #ced4da;
        border-radius: 10px;
        padding: 15px 30px;
        display: inline-block;
        margin: 20px 0;
    }

    /* হোম পেজে ফেরার বাটন (আমাদের ওয়ার্ম অরেঞ্জ থিম) */
    .btn-continue {
        background: linear-gradient(135deg, #ff7e5f 0%, #feb47b 100%);
        color: white;
        border: none;
        border-radius: 25px;
        padding: 12px 35px;
        font-weight: bold;
        font-size: 1.1rem;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

        .btn-continue:hover {
            background: linear-gradient(135deg, #feb47b 0%, #ff7e5f 100%);
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(255, 126, 95, 0.4);
            color: white;
        }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8 text-center">

            <div class="card success-card">

                <div class="success-icon-wrapper">
                    <i class="fas fa-check-circle success-icon"></i>
                </div>

                <h1 class="fw-bold text-dark mb-3">Order Successful!</h1>
                <p class="text-muted fs-5 mb-4">
                    Thank you for your purchase. Your order has been placed successfully and is currently being processed.
                </p>

                <div class="order-id-box">
                    <span class="text-muted d-block mb-1">Your Order Reference Number:</span>
                    <strong class="fs-4 text-dark">#ORD-@DateTime.Now.ToString("ddMMyy-HHmm")</strong>
                </div>

                <p class="text-muted small mb-5">
                    <i class="fas fa-envelope-open-text me-1 text-warning"></i> We will send you an email confirmation with details and tracking info shortly.
                </p>

                <div>
                    <a href="/Home/Index" class="btn-continue">
                        <i class="fas fa-shopping-bag me-2"></i> Continue Shopping
                    </a>
                </div>

            </div>

        </div>
    </div>
</div>