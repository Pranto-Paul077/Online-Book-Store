@{
    ViewData["Title"] = "Login";
}

<style>
    body {
        background-color: #f4f7f6; /* Soft light gray background */
    }

    .auth-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08); /* Soft shadow */
    }

    .auth-header {
        font-weight: 600;
        color: #333;
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card auth-card p-4">
                <div class="card-body">

                    <h2 class="auth-header text-center mb-2">Welcome Back!</h2>
                    <p class="text-center text-muted mb-4">Please login to your account</p>

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-danger text-center" role="alert">
                            @ViewBag.Message
                        </div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Email Address</label>
                            <input name="email" type="email" class="form-control" placeholder="Enter your email" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Password</label>
                            <input name="password" type="password" class="form-control" placeholder="Enter your password" required />
                        </div>

                        <button type="submit" class="btn btn-success w-100 mb-3" style="border-radius: 25px; padding: 10px; font-weight: bold;">
                            Login
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <span class="text-muted">Don't have an account?</span>
                        <a href="/Account/Register" class="text-decoration-none fw-bold" style="color: #198754;">Create new account</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>