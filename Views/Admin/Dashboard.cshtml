@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>
    /* ড্যাশবোর্ড কার্ডের সুন্দর হোভার ইফেক্ট */
    .action-card {
        border-radius: 15px;
        transition: all 0.3s ease;
        text-decoration: none;
        color: inherit;
        display: block;
        border: 1px solid #e0e0e0;
    }

        .action-card:hover {
            transform: translateY(-8px); /* মাউস নিলে কার্ডটি উপরে উঠবে */
            box-shadow: 0 15px 25px rgba(0,0,0,0.1);
            color: inherit;
            border-color: transparent;
        }

    /* পরিসংখ্যান কার্ডের ডিজাইন */
    .stat-card {
        border-left: 5px solid;
        border-radius: 10px;
    }

        .stat-card.blue {
            border-left-color: #0d6efd;
        }

        .stat-card.green {
            border-left-color: #198754;
        }

        .stat-card.orange {
            border-left-color: #fd7e14;
        }
</style>

<div class="container mt-4 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
        <h2 class="fw-bold text-dark mb-0">
            <i class="fas fa-tachometer-alt text-primary me-2"></i> Admin Dashboard
        </h2>
        <span class="badge bg-success fs-6 py-2 px-3 rounded-pill">
            <i class="fas fa-user-shield me-1"></i> Logged in as Admin
        </span>
    </div>

    <div class="row mb-5">
        <div class="col-md-4">
            <div class="card stat-card blue shadow-sm mb-3 border-0 bg-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase fw-bold mb-1">Total Books</h6>
                            <h3 class="fw-bold mb-0 text-dark">150+</h3>
                        </div>
                        <i class="fas fa-book fa-2x text-primary opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card green shadow-sm mb-3 border-0 bg-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase fw-bold mb-1">Total Users</h6>
                            <h3 class="fw-bold mb-0 text-dark">45</h3>
                        </div>
                        <i class="fas fa-users fa-2x text-success opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card orange shadow-sm mb-3 border-0 bg-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted text-uppercase fw-bold mb-1">Total Orders</h6>
                            <h3 class="fw-bold mb-0 text-dark">320</h3>
                        </div>
                        <i class="fas fa-shopping-cart fa-2x text-warning opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="mb-4 text-secondary fw-bold"><i class="fas fa-bolt text-warning me-2"></i> Quick Actions</h4>

    <div class="row">
        <div class="col-md-6 mb-4">
            <a href="/Admin/AddBook" class="card action-card bg-white shadow-sm text-center p-5">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="fas fa-plus-circle fa-4x text-primary"></i>
                    </div>
                    <h3 class="fw-bold text-dark">Add New Book</h3>
                    <p class="text-muted mt-2">Upload a new book to the store with its cover image, author name, and price details.</p>
                </div>
            </a>
        </div>

        <div class="col-md-6 mb-4">
            <a href="/Admin/BookList" class="card action-card bg-white shadow-sm text-center p-5">
                <div class="card-body">
                    <div class="mb-3">
                        <i class="fas fa-tasks fa-4x text-success"></i>
                    </div>
                    <h3 class="fw-bold text-dark">Manage Books</h3>
                    <p class="text-muted mt-2">View the complete list of books. Edit their information, update stock, or delete them.</p>
                </div>
            </a>
        </div>
    </div>

</div>