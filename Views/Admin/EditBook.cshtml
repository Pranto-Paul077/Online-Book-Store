@model OnlineBookStore.Models.Book
@{
    ViewData["Title"] = "Edit Book Details";
}

<style>
    .form-card {
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        border: none;
    }

    .form-header {
        /* এডিট পেজের জন্য একটু ভিন্ন (সবুজ-নীল) গ্রেডিয়েন্ট ব্যবহার করা হলো */
        background: linear-gradient(135deg, #20bf55 0%, #01baef 100%);
        border-radius: 15px 15px 0 0 !important;
        color: white;
    }

    .form-label {
        font-weight: 600;
        color: #495057;
    }

    .form-control:focus {
        border-color: #01baef;
        box-shadow: 0 0 0 0.25rem rgba(1, 186, 239, 0.25);
    }

    .btn-update {
        background: linear-gradient(135deg, #20bf55 0%, #01baef 100%);
        border: none;
        border-radius: 25px;
        padding: 10px 20px;
        font-weight: bold;
        transition: transform 0.2s ease;
    }

        .btn-update:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(32, 191, 85, 0.4);
        }
    /* বর্তমান ছবির স্টাইল */
    .current-image {
        width: 120px;
        height: 160px;
        object-fit: cover;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="mb-3">
                <a href="/Admin/BookList" class="text-decoration-none text-secondary fw-bold">
                    <i class="fas fa-arrow-left me-1"></i> Back to Book List
                </a>
            </div>

            <div class="card form-card">
                <div class="card-header form-header text-center py-4">
                    <h3 class="mb-0 fw-bold"><i class="fas fa-edit me-2"></i> Update Book Information</h3>
                    <p class="mb-0 text-light opacity-75 small mt-1">Make changes to the details of - <strong>@Model.Title</strong></p>
                </div>

                <div class="card-body p-4 p-md-5">

                    <div class="text-center mb-4 pb-3 border-bottom">
                        <p class="text-muted small fw-bold mb-2">Current Cover Image</p>
                        <img src="@Model.ImagePath" alt="@Model.Title" class="current-image" onerror="this.src='/images/no-image.jpg'" />
                    </div>

                    <form asp-action="EditBook" method="post">

                        <input type="hidden" asp-for="BookId" />
                        <input type="hidden" asp-for="ImagePath" />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label"><i class="fas fa-heading text-primary me-1"></i> Book Title</label>
                                <input asp-for="Title" class="form-control" placeholder="Enter book title" required />
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label class="form-label"><i class="fas fa-user-edit text-success me-1"></i> Author Name</label>
                                <input asp-for="Author" class="form-control" placeholder="Enter author's name" required />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label"><i class="fas fa-tag text-warning me-1"></i> Price (৳)</label>
                                <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label class="form-label"><i class="fas fa-boxes text-info me-1"></i> Stock Quantity</label>
                                <input asp-for="Stock" type="number" class="form-control" placeholder="e.g. 50" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label"><i class="fas fa-align-left text-secondary me-1"></i> Description / Synopsis</label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Update the summary about the book..." required></textarea>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-update text-white btn-lg">
                                <i class="fas fa-check-circle me-1"></i> Save Changes
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>