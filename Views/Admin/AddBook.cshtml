@model OnlineBookStore.Models.Book
@{
    ViewData["Title"] = "Add New Book";
}

<style>
    .form-card {
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        border: none;
    }

    .form-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 15px 15px 0 0 !important;
        color: white;
    }

    .form-label {
        font-weight: 600;
        color: #495057;
    }

    .form-control:focus {
        border-color: #764ba2;
        box-shadow: 0 0 0 0.25rem rgba(118, 75, 162, 0.25);
    }

    .btn-submit {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 25px;
        padding: 10px 20px;
        font-weight: bold;
        transition: transform 0.2s ease;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(118, 75, 162, 0.4);
        }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="mb-3">
                <a href="/Admin/Dashboard" class="text-decoration-none text-secondary fw-bold">
                    <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
                </a>
            </div>

            <div class="card form-card">
                <div class="card-header form-header text-center py-4">
                    <h3 class="mb-0 fw-bold"><i class="fas fa-book-medical me-2"></i> Add New Book</h3>
                    <p class="mb-0 text-light opacity-75 small mt-1">Fill out the form below to add a new book to the store</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="AddBook" method="post" enctype="multipart/form-data">

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label"><i class="fas fa-heading text-primary me-1"></i> Book Title</label>
                                <input asp-for="Title" class="form-control" placeholder="Enter book title" required />
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label class="form-label"><i class="fas fa-user-edit text-success me-1"></i> Author Name</label>
                                <input asp-for="Author" class="form-control" placeholder="Enter author's name" required />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label"><i class="fas fa-tag text-warning me-1"></i> Price (৳)</label>
                                <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label class="form-label"><i class="fas fa-boxes text-info me-1"></i> Stock Quantity</label>
                                <input asp-for="Stock" type="number" class="form-control" placeholder="e.g. 50" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label"><i class="fas fa-align-left text-secondary me-1"></i> Description / Synopsis</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Write a short summary about the book..." required></textarea>
                        </div>

                        <div class="mb-5 p-3 border rounded bg-light">
                            <label class="form-label"><i class="fas fa-image text-danger me-1"></i> Upload Book Cover Image</label>
                            <input type="file" name="imageFile" class="form-control form-control-lg" accept="image/*" required />
                            <small class="text-muted mt-1 d-block">Recommended format: JPG, PNG. Max size: 2MB.</small>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-submit text-white btn-lg">
                                <i class="fas fa-save me-1"></i> Save Book Details
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>