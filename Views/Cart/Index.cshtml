@model IEnumerable<OnlineBookStore.Models.Cart>
@{
    ViewData["Title"] = "My Shopping Cart";
    decimal grandTotal = 0;
}

<style>
    .cart-container {
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border: none;
        background-color: #fff;
        overflow: hidden;
    }

    .cart-header {
        background-color: #f8f9fa;
        border-bottom: 2px solid #eee;
        font-weight: 600;
        color: #495057;
    }

    .btn-remove {
        color: #dc3545;
        background-color: rgba(220,53,69,0.1);
        border: none;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

        .btn-remove:hover {
            background-color: #dc3545;
            color: white;
            transform: scale(1.1);
        }

    .checkout-section {
        background-color: #fcfcfc;
        border-radius: 15px;
        border: 1px dashed #ced4da;
    }

    .btn-checkout {
        background: linear-gradient(135deg, #ff7e5f 0%, #feb47b 100%);
        color: white;
        border: none;
        border-radius: 25px;
        padding: 12px 30px;
        font-weight: bold;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

        .btn-checkout:hover {
            background: linear-gradient(135deg, #feb47b 0%, #ff7e5f 100%);
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(255,126,95,0.4);
            color: white;
        }
</style>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0"><i class="fas fa-shopping-cart" style="color: #ff7e5f;"></i> Your Shopping Cart</h2>
        <a href="/Home/Index" class="text-decoration-none text-muted fw-bold hover-orange"><i class="fas fa-arrow-left me-1"></i> Continue Shopping</a>
    </div>

    <div class="row">
        <div class="col-lg-8 mb-4">
            <div class="card cart-container">
                <div class="card-body p-0 table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="cart-header">
                            <tr>
                                <th class="py-3 px-4">Book</th>
                                <th class="py-3 text-center">Price</th>
                                <th class="py-3 text-center">Quantity</th>
                                <th class="py-3 text-center">Total</th>
                                <th class="py-3 text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    // item.Book.Price ব্যবহার করা হয়েছে
                                    decimal itemTotal = item.Book.Price * item.Quantity;
                                    grandTotal += itemTotal;

                                    <tr>
                                        <td class="px-4 py-3">
                                            <div class="d-flex align-items-center">
                                                <img src="@item.Book.ImagePath" alt="@item.Book.Title" style="width: 50px; height: 70px; object-fit: cover; border-radius: 5px; margin-right: 15px;" onerror="this.src='/images/no-image.jpg'" />
                                                <span class="fw-bold text-dark">@item.Book.Title</span>
                                            </div>
                                        </td>

                                        <td class="text-center text-muted">৳ @item.Book.Price.ToString("0.00")</td>

                                        <td class="text-center fw-bold">
                                            <span class="badge bg-light text-dark border px-3 py-2 fs-6">@item.Quantity</span>
                                        </td>

                                        <td class="text-center text-success fw-bold">৳ @itemTotal.ToString("0.00")</td>

                                        <td class="text-center">
                                            <a href="/Cart/Remove/@item.CartId" class="btn-remove" title="Remove" onclick="return confirm('Remove this book from your cart?');">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <i class="fas fa-shopping-basket fa-3x mb-3 opacity-50"></i>
                                        <h4>Your cart is currently empty.</h4>
                                        <p>Go back to the store and add some awesome books!</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="checkout-section p-4 shadow-sm">
                <h4 class="fw-bold border-bottom pb-3 mb-4"><i class="fas fa-receipt text-secondary me-2"></i> Order Summary</h4>

                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Subtotal:</span>
                    <span class="fw-bold text-dark">৳ @grandTotal.ToString("0.00")</span>
                </div>
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted">Shipping:</span>
                    <span class="text-success fw-bold">Free</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="fs-5 fw-bold text-dark">Grand Total:</span>
                    <span class="fs-4 fw-bold" style="color: #ff7e5f;">৳ @grandTotal.ToString("0.00")</span>
                </div>

                <div class="d-grid">
                    <a href="/Order/Checkout" class="btn-checkout text-center">Proceed to Checkout <i class="fas fa-arrow-right ms-2"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>